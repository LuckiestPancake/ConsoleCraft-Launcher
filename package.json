{
"name": "cc-launcher",
"productName": "ConsoleCraft_Launcher",
"author": "LuckiestPancake",
"description": "A Minecraft launcher for Legacy Console Edition that tries to add quality of life features and simplisitc!",
"version": "1.0.0",
"main": "main.js",
"dependencies": {
"electron-store": "^6.0.1",
"extract-zip": "^2.0.1"
},
"devDependencies": {
"electron": "^41.0.1",
"electron-builder": "^26.8.1"
},
"scripts": {
"start": "electron .",
"dist": "electron-builder --win"
},
"build": {
"appId": "com.consolecraft.launcher",
"productName": "ConsoleCraft_Launcher",
"directories": {
"output": "dist"
},
"files": [
"**/*"
],
"win": {
"target": "portable",
"icon": "media/favicon.png"
}
}
}
